#!/usr/bin/env bash
# source: https://zenn.dev/nalt/articles/lazygit-gemini?locale=en
# ==========================================
# Common Settings & Checks
# ==========================================

if ! command -v opencode &>/dev/null; then
  gum style --foreground 196 "Error: opencode not found in PATH."
  read -n 1 -s -r -p "Press any key to exit..."
  exit 1
fi

# Get diff
DIFF=$(git diff --cached)
if [ -z "$DIFF" ]; then
  gum style --foreground 196 "No staged changes."
  read -n 1 -s -r -p "Press any key to exit..."
  exit 1
fi

# ==========================================
# Candidate Generation by AI
# ==========================================

# Prompt: Requesting a total of 2 : concise and detailed versions
# TODO: May consider only one detailed message or message with body (will need jq parser config changes)
PROMPT="
You are a commit message generator. Analyze the following git diff and generate 2 distinct commit messages conforming:

Generate the following 2 variations:
1. English: A standard, concise message.
2. English: A slightly more detailed message explaining the 'what'.

Output MUST be a valid JSON array of strings, like:
[\"feat: english message\", \"fix: english detailed...\"]

In case of dotfiles, use \"software_name: ...\"

Lowercase is preffered

Do NOT output commit body, in one line only

Do NOT output markdown code blocks. Output ONLY the JSON array.

Diff:
$DIFF
"

# Generate candidates using opencode
TMP_PROMPT=$(mktemp)
TMP_RESPONSE=$(mktemp)
echo "$PROMPT" > "$TMP_PROMPT"

gum spin --spinner dot --title "Generating candidates..." -- \
  bash -c "opencode run --model opencode-go/deepseek-v4-flash \"\$(cat \"$TMP_PROMPT\")\" > \"$TMP_RESPONSE\" 2>/dev/null"

CANDIDATES=$(cat "$TMP_RESPONSE")
rm -f "$TMP_PROMPT" "$TMP_RESPONSE"

# Remove Markdown code blocks (just in case) and parse JSON array
CHOICES=$(echo "$CANDIDATES" | sed 's/^```json//g' | sed 's/^```//g' | jq -r '.[]' 2>/dev/null)

if [ -z "$CHOICES" ]; then
  gum style --foreground 196 "Failed to parse candidates."
  echo "Raw Response: $CANDIDATES"
  read -n 1 -s -r -p "Press any key to exit..."
  exit 1
fi

# ==========================================
# Candidate Selection (gum choose)
# ==========================================
SELECTED_MSG=$(echo "$CHOICES" | gum choose --header "Pick a commit message:")

if [ -z "$SELECTED_MSG" ]; then
  echo "Cancelled."
  exit 0
fi

# ==========================================
# Final Edit (gum write)
# ==========================================
# TODO: Open default editor bydefault, git commit message editor window?
#
# Open editor with the selected candidate as the initial value
FINAL_MSG=$(echo "$SELECTED_MSG" | gum write --width 80 --height 5 --placeholder "Edit commit message...")

# Commit if input is present
if [ -n "$FINAL_MSG" ]; then
  git commit -m "$FINAL_MSG"
else
  echo "Commit cancelled."
fi
