{
  home.sessionPath = [
    # pipx pkgs
    "$HOME/.local/bin"
    # cargo pkgs
    "$HOME/.cargo/bin"
    # custom scripts
    "$HOME/bin"
    # go pkgs
    "$HOME/go/bin"
    # mason pkgs
    "$HOME/.local/share/nvim/mason/bin"
    # pnpm pkgs
    "$HOME/.local/share/pnpm"
    # composer pkgs
    "$HOME/.config/composer/vendor/bin"
    # bun pkgs
    "$HOME/.cache/.bun/bin"
  ];
}
