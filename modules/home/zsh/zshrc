cfp() {                    # copy file path
  readlink -f $1 | wl-copy |
    readlink -f $1
}

# github
ghrc() {
  gh repo create "$1" --source=. --public --remote=origin --push
}

ntd() {
  nix-tree --derivation "nixpkgs#$1"
}


freezer() {
  if [ -z "$1" ]; then
    echo "Usage: freezer <code_file>"
    return 1
  fi

  local codefile="$1"

  if [ ! -f "$codefile" ]; then
    echo "Error: File '$codefile' does not exist."
    return 1
  fi

  local output="${codefile}.png"

  command freeze "$codefile" -o "$output"
}

